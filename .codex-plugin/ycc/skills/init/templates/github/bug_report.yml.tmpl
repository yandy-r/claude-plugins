name: Bug report
description: "Report a reproducible bug in {{PROJECT_NAME}}"
title: "[Bug]: "
labels: ["type:bug", "status:needs-triage"]
body:
  - type: markdown
    attributes:
      value: |
        Thanks for taking the time to report a bug in **{{PROJECT_NAME}}**. Please fill out
        the form below so we can reproduce and fix it.

  - type: input
    id: version
    attributes:
      label: Version
      description: "Version or commit hash of {{PROJECT_NAME}}"
      placeholder: "v1.0.0 or abc1234"
    validations:
      required: true

  - type: dropdown
    id: environment
    attributes:
      label: Environment
      description: "Where are you running {{PROJECT_NAME}}?"
      options:
        - Linux
        - macOS
        - Windows
        - Other
    validations:
      required: true

  - type: textarea
    id: steps
    attributes:
      label: Steps to Reproduce
      description: "Detailed steps to reproduce the behavior."
      value: |
        1.
        2.
        3.
    validations:
      required: true

  - type: textarea
    id: expected
    attributes:
      label: Expected Behavior
      description: "What you expected to happen."
    validations:
      required: true

  - type: textarea
    id: actual
    attributes:
      label: Actual Behavior
      description: "What actually happened."
    validations:
      required: true

  - type: textarea
    id: logs
    attributes:
      label: Logs / Stack Trace
      description: "Paste relevant log output or stack traces. Use code blocks for logs."
      render: shell
    validations:
      required: false

  - type: checkboxes
    id: duplicate-check
    attributes:
      label: Duplicate Check
      description: "Please search existing issues before filing a new one."
      options:
        - label: "I have searched existing issues and this bug has not been reported."
          required: true
