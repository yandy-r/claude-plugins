{
  "name": "ycc",
  "description": "Scripts for YCC",
  "scripts": {
    "lint": "scripts/lint.sh --python --docs --shell",
    "lint:modified": "scripts/lint.sh --modified --python --docs --shell",
    "lint:staged": "scripts/lint.sh --staged --python --docs --shell",
    "lint:unstaged": "scripts/lint.sh --unstaged --python --docs --shell",
    "lint:fix": "scripts/lint.sh --fix --python --docs --shell",
    "lint:fix:modified": "scripts/lint.sh --fix --modified --python --docs --shell",
    "format": "scripts/format.sh --python --docs",
    "format:modified": "scripts/format.sh --modified --python --docs",
    "format:staged": "scripts/format.sh --staged --python --docs",
    "format:unstaged": "scripts/format.sh --unstaged --python --docs",
    "install:all": "./install.sh --target all --settings --mcp --hooks",
    "install:all:local": "./install.sh --target all --mode local --settings --mcp --hooks",
    "install:all:repo": "./install.sh --target all --mode repo --settings --mcp --hooks",
    "install:all:base": "./install.sh --target all --only base",
    "install:all:settings": "./install.sh --target all --only settings",
    "install:all:mcp": "./install.sh --target all --only mcp",
    "install:claude": "./install.sh --target claude --settings --mcp --hooks",
    "install:claude:local": "./install.sh --target claude --mode local --settings --mcp --hooks",
    "install:claude:repo": "./install.sh --target claude --mode repo --settings --mcp --hooks",
    "install:claude:base": "./install.sh --target claude --only base",
    "install:claude:base:local": "./install.sh --target claude --mode local --only base",
    "install:claude:base:repo": "./install.sh --target claude --mode repo --only base",
    "install:claude:settings": "./install.sh --target claude --only settings",
    "install:claude:mcp": "./install.sh --target claude --only mcp",
    "install:claude:hooks": "./install.sh --target claude --only hooks",
    "install:cursor": "./install.sh --target cursor --settings --mcp",
    "install:cursor:base": "./install.sh --target cursor --only base",
    "install:cursor:settings": "./install.sh --target cursor --only settings",
    "install:cursor:mcp": "./install.sh --target cursor --only mcp",
    "install:codex": "./install.sh --target codex --settings",
    "install:codex:local": "./install.sh --target codex --mode local --settings",
    "install:codex:repo": "./install.sh --target codex --mode repo --settings",
    "install:codex:base": "./install.sh --target codex --only base",
    "install:codex:base:local": "./install.sh --target codex --mode local --only base",
    "install:codex:base:repo": "./install.sh --target codex --mode repo --only base",
    "install:codex:settings": "./install.sh --target codex --only settings",
    "install:opencode": "./install.sh --target opencode --settings",
    "install:opencode:base": "./install.sh --target opencode --only base",
    "install:opencode:settings": "./install.sh --target opencode --only settings",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "lefthook": "^1.8.0"
  }
}
