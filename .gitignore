# macOS
.DS_Store

# Dependencies
node_modules/

# Environment
.env
.env.local
.env.*.local

# Logs
*.log

# Temporary files
*.tmp
*.swp
*~

# CLAUDE
/.claude/settings.local.json

# IDE
.idea/
.vscode/
*.sublime-*

# Pinned tools (scripts/install-shellcheck.sh installs repo-local binary here)
/tools/shellcheck

