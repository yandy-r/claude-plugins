#!/usr/bin/env bash
set -euo pipefail

sig_path=""
artifact=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        -x) sig_path="${2:-}"; shift 2 ;;
        -m) artifact="${2:-}"; shift 2 ;;
        *) shift ;;
    esac
done

if [[ -z "${sig_path}" ]]; then
    printf 'minisign fixture: missing required -x signature path\n' >&2
    exit 1
fi

if [[ -z "${artifact}" ]]; then
    printf 'minisign fixture: missing required -m artifact path\n' >&2
    exit 1
fi

printf 'fake-minisign signature for %s\n' "${artifact}" > "${sig_path}"
exit 0
