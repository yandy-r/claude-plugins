# generic-redaction.rules — commercial compliance adapter
# Format: NAME:<rule-name> (optional, applies to next RE)
#         RE:<python-regex>
# Lines starting with # are comments. Blank lines ignored.
# Loaded by yci/skills/_shared/telemetry-sanitizer via the *-redaction.rules
# discovery glob (see load_adapter_rules.py). See ADAPTER.md § Redaction rules
# for the class descriptions and rationale.
#
# This adapter covers: secrets, private keys, RFC1918/link-local IPs, and
# internal hostnames. No PHI, no PCI, no regulator-specific markers.

# --- secrets ---

NAME:aws_access_key
RE:AKIA[0-9A-Z]{16}

NAME:gcp_api_key
RE:AIza[0-9A-Za-z_\-]{35}

NAME:github_token
RE:gh[pousr]_[A-Za-z0-9_]{36,}

NAME:password_assignment
RE:(?i)(password|passwd|pwd)\s*[:=]\s*\S+

NAME:bearer_token
RE:(?i)bearer\s+[A-Za-z0-9._~+/\-]+=*

# --- private keys ---

NAME:private_key_header
RE:-----BEGIN (?:(?:RSA|DSA|EC|OPENSSH|ENCRYPTED) )?PRIVATE KEY-----

# --- RFC1918 + link-local IPs ---

NAME:rfc1918_10
RE:\b10\.\d{1,3}\.\d{1,3}\.\d{1,3}\b

NAME:rfc1918_172
RE:\b172\.(?:1[6-9]|2[0-9]|3[0-1])\.\d{1,3}\.\d{1,3}\b

NAME:rfc1918_192
RE:\b192\.168\.\d{1,3}\.\d{1,3}\b

NAME:linklocal_169
RE:\b169\.254\.\d{1,3}\.\d{1,3}\b

# --- internal hostnames ---

NAME:internal_hostname
RE:(?i)\b[a-z0-9][a-z0-9\-]*\.(?:internal|corp|local|lan|intranet)\b
