# redaction.rules — commercial compliance adapter
# Format: <category><TAB><pcre>
# One rule per line. Lines starting with # are comments.
# See ADAPTER.md § Redaction rules for the class descriptions and rationale.
#
# This adapter covers: secrets, private keys, RFC1918/link-local IPs, and
# internal hostnames. No PHI, no PCI, no regulator-specific markers.

# secrets
secret	AKIA[0-9A-Z]{16}
secret	AIza[0-9A-Za-z_-]{35}
secret	gh[pousr]_[A-Za-z0-9_]{36,}
secret	(?i)(password|passwd|pwd)\s*[:=]\s*\S+
secret	(?i)bearer\s+[A-Za-z0-9._~+/-]+=*

# private keys
private-key	-----BEGIN (?:RSA|DSA|EC|OPENSSH|PRIVATE) PRIVATE KEY-----

# RFC1918 + link-local
ip	\b10\.\d{1,3}\.\d{1,3}\.\d{1,3}\b
ip	\b172\.(?:1[6-9]|2[0-9]|3[0-1])\.\d{1,3}\.\d{1,3}\b
ip	\b192\.168\.\d{1,3}\.\d{1,3}\b
ip	\b169\.254\.\d{1,3}\.\d{1,3}\b

# hostnames
hostname	(?i)\b[a-z0-9][a-z0-9-]*\.(?:internal|corp|local|lan|intranet)\b
