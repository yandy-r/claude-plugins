# HIPAA PHI-shaped patterns (supplement core sanitizer; not clinical advice).
# Format: RE:<Python regex>

NAME:ssn
RE:\b\d{3}-\d{2}-\d{4}\b

NAME:mrn_like
RE:\bMRN\s*[:#]?\s*\d{6,12}\b

NAME:dob
RE:\b(?:DOB|Date of Birth)\s*[:#]?\s*\d{4}-\d{2}-\d{2}\b

NAME:patient_name
RE:(?iu)\bPatient\s*Name\s*[:#]?\s*(?:[^\W\d_](?:[^\W\d_]|['’-]){0,31}\.?)(?:\s+(?:[^\W\d_](?:[^\W\d_]|['’-]){0,31}\.?)){0,3}(?:\s+(?:jr|sr|ii|iii|iv)\.?)?\b
