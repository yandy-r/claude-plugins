# .gitignore — generated by init for {{PROJECT_NAME}}
#
# Tune this file after generation: add project-specific scratch dirs, generated
# assets, and local secrets. Sections below are driven by detected profile
# (primary_language + secondary_languages); mixed-stack repos receive every
# matching block.

# ==============================================================================
# OS / editor / tooling (universal)
# ==============================================================================
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.cursor/
.zed/

# ==============================================================================
# Environment / secrets — NEVER commit these
# ==============================================================================
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.p12

# ==============================================================================
# opencode / agent scratch
# ==============================================================================
.claude/worktrees/
.claude/session-data/
.claude/plans/

{{#IF_RUST}}
# ==============================================================================
# Rust
# ==============================================================================
/target/
**/*.rs.bk
# Cargo.lock — keep for binaries; add this line back for libraries
{{/IF_RUST}}
{{#IF_GO}}
# ==============================================================================
# Go
# ==============================================================================
/bin/
/dist/
*.exe
*.test
*.out
vendor/
{{/IF_GO}}
{{#IF_PYTHON}}
# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
htmlcov/
dist/
build/
.venv/
venv/
{{/IF_PYTHON}}
{{#IF_TS}}
# ==============================================================================
# Node / TypeScript
# ==============================================================================
node_modules/
dist/
build/
.next/
.turbo/
.cache/
*.tsbuildinfo
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
{{/IF_TS}}
{{#IF_TERRAFORM}}
# ==============================================================================
# Terraform
# ==============================================================================
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
{{/IF_TERRAFORM}}
