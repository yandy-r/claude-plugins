{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "instructions": [
    "AGENTS.md"
  ],
  "provider": {
    "openai": {
      "models": {
        "gpt-5.4": {
          "reasoningEffort": "high",
          "textVerbosity": "low"
        }
      }
    }
  },
  "mcp": {
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_API_TOKEN}"
      }
    }
  }
}
