name: Lint

on:
  pull_request:
  push:
    branches: [main, master]

concurrency:
  group: lint-${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
{{#IF_RUST}}
  lint-rust:
    if: hashFiles('Cargo.toml') != ''
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: dtolnay/rust-toolchain@stable
        with:
          components: rustfmt, clippy
      - uses: Swatinem/rust-cache@v2
      - run: ./scripts/style.sh lint --rust
{{/IF_RUST}}

{{#IF_GO}}
  lint-go:
    if: hashFiles('go.mod') != ''
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: stable
          cache: true
      - uses: golangci/golangci-lint-action@v6
        with:
          version: latest
          args: --timeout=5m
{{/IF_GO}}

{{#IF_TS}}
  lint-ts:
    if: hashFiles('package.json') != ''
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: lts/*
          cache: npm
      - run: npm ci --no-audit --no-fund
      - run: ./scripts/style.sh lint --ts
{{/IF_TS}}

{{#IF_PYTHON}}
  lint-python:
    if: hashFiles('pyproject.toml') != '' || hashFiles('requirements.txt') != '' || hashFiles('setup.py') != ''
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      - run: pip install --no-cache-dir ruff black
      - run: ./scripts/style.sh lint --python
{{/IF_PYTHON}}

{{#IF_SHELL}}
  lint-shell:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Install shellcheck
        run: sudo apt-get update && sudo apt-get install -y shellcheck
      - run: ./scripts/style.sh lint --shell
{{/IF_SHELL}}

{{#IF_DOCS}}
  lint-docs:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: lts/*
      - run: npx --yes markdownlint-cli "**/*.md" --ignore-path .markdownlintignore
      - run: npx --yes prettier --check "**/*.{md,mdx,json,jsonc,yaml,yml}"
{{/IF_DOCS}}
